generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A mutable developer workspace that can later be shared as a read-only snapshot.
model Workspace {
  id                String              @id @default(cuid())
  ownerKey          String              @map("owner_key")
  name              String
  description       String?
  selectedNetwork   String              @default("testnet") @map("selected_network")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  savedContracts    SavedContract[]
  savedInteractions SavedInteraction[]
  artifacts         WorkspaceArtifact[]
  shares            ShareLink[]

  @@index([ownerKey])
  @@index([updatedAt])
  @@map("workspaces")
}

model SavedContract {
  id          String     @id @default(cuid())
  workspaceId String     @map("workspace_id")
  contractId  String     @map("contract_id")
  network     String
  label       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([contractId, network])
  @@map("saved_contracts")
}

model SavedInteraction {
  id            String     @id @default(cuid())
  workspaceId   String     @map("workspace_id")
  contractId    String?    @map("contract_id")
  functionName  String     @map("function_name")
  name          String?
  network       String
  argumentsJson Json       @map("arguments_json")
  createdAt     DateTime   @default(now()) @map("created_at")
  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([contractId, network])
  @@index([functionName, network])
  @@map("saved_interactions")
}

/// File and derived metadata captured inside a workspace, including WASM uploads.
model WorkspaceArtifact {
  id          String     @id @default(cuid())
  workspaceId String     @map("workspace_id")
  kind        String
  name        String
  network     String?
  hash        String?
  metadata    Json?
  createdAt   DateTime   @default(now()) @map("created_at")
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, kind])
  @@index([hash])
  @@map("workspace_artifacts")
}

/// Immutable, read-only links that capture a point-in-time workspace snapshot.
model ShareLink {
  id            String     @id @default(cuid())
  workspaceId    String     @map("workspace_id")
  token         String     @unique
  label         String?
  snapshotJson  Json       @map("snapshot_json")
  expiresAt     DateTime?  @map("expires_at")
  revokedAt     DateTime?  @map("revoked_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("share_links")
}
